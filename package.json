{
  "name": "@i-giann/open-meteo-wrapper",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/IaconoG/open-meteo-wrapper-npm.git"
  },
  "description": "Un wrapper completo para la API de Open-Meteo con hooks de React y servicios reutilizables",
  "keywords": [
    "weather",
    "open-meteo",
    "react",
    "zustand",
    "vite",
    "typescript",
    "weather-api",
    "meteorology",
    "forecast",
    "climate"
  ],
  "author": "Giann Iacono <email@example.com>",
  "homepage": "https://github.com/IaconoG/open-meteo-wrapper-npm#readme",
  "bugs": {
    "url": "https://github.com/IaconoG/open-meteo-wrapper-npm/issues"
  },
  "private": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "module": "./dist/index.esm.js",
  "sideEffects": false,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:js && npm run build:types",
    "build:js": "vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write .",
    "test": "jest"
  },
  "dependencies": {
    "immer": "^10.1.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/testing-library__react": "^10.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "jest-fixed-jsdom": "^0.0.9",
    "jiti": "^2.6.1",
    "msw": "^2.7.3",
    "ts-jest": "^29.2.6",
    "tsc-alias": "^1.8.15",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.1.0"
  }
}
